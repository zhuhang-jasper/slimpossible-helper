{
  "name": "slimpossible-2026",
  "private": true,
  "version": "2.1.1",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "check-node-version": "node scripts/check-node-version.js",
    "prebuild": "npm run -s check-node-version",
    "dev": "npm run -s prebuild && vite",
    "build": "vite build",
    "lint+format:check": "npm run lint:check && npm run format:check",
    "lint+format:fix": "npm run lint:fix && npm run format:fix",
    "lint:check": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format:check": "oxfmt -c .oxfmtrc.json --check .",
    "format:fix": "oxfmt -c .oxfmtrc.json --write .",
    "preview": "vite preview",
    "updateDependencies": "npm update --save",
    "checkForUpdates": "npx npm-check-updates",
    "checkForUpdates:minor": "npx npm-check-updates --target minor",
    "bumpver:patch": "npm version patch --no-git-tag-version",
    "bumpver:minor": "npm version minor --no-git-tag-version",
    "bumpver:major": "npm version major --no-git-tag-version"
  },
  "dependencies": {
    "lucide-react": "^1.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@date-fns/tz": "^1.5.0",
    "@vitejs/plugin-react": "^4.3.4",
    "date-fns": "^4.3.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "vite": "^6.0.7"
  }
}
