root = true

[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = space
indent_size = 2

# Match oxfmt printWidth; only types we routinely format — avoids implying a wrap
# width for lockfiles, YAML env templates, CSV, minified assets, etc.
[*.{ts,tsx,js,jsx,mjs,cjs,json,css,scss,html}]
max_line_length = 150

[*.md]
max_line_length = off
trim_trailing_whitespace = false
