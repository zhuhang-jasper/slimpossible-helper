{
  // EDITOR
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "always",
    "source.format.oxc": "always"
  },
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",

  // OXC
  "oxc.fmt.configPath": ".oxfmtrc.json",

  // TYPESCRIPT / JAVASCRIPT
  "js/ts.preferences.importModuleSpecifierEnding": "minimal",
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.updateImportsOnFileMove.enabled": "always",

  // CSS
  "css.lint.unknownAtRules": "ignore",

  // TERMINAL
  // ZDOTDIR → .vscode/zdotdir/.zshrc: nvm + ~/.zshrc, then nvm use (.nvmrc) for sidebar npm scripts etc.
  "terminal.integrated.defaultProfile.osx": "zsh (workspace nvm)",
  "terminal.integrated.profiles.osx": {
    "zsh (workspace nvm)": {
      "path": "/bin/zsh",
      "args": ["-i"],
      "icon": "terminal",
      "env": {
        "ZDOTDIR": "${workspaceFolder}/.vscode/zdotdir"
      }
    }
  },

  // LANGUAGE-SPECIFIC FORMATTERS
  "[css]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "kennylong.kubernetes-yaml-formatter"
  },
  "[html]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[scss]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[yaml]": {
    "editor.defaultFormatter": "kennylong.kubernetes-yaml-formatter"
  }
}
